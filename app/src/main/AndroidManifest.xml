<?xml version="1.0" encoding="utf-8"?>
<!--
  PirateDroid — AndroidManifest.xml
  Uprawnienia wymagane do działania terminala i dumpowania logów.
  UWAGA: READ_LOGS i REBOOT wymagają root lub podpisania kluczem systemowym.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.piratedroid.terminal">

    <!-- ════════════════════════════════════════════════════════ -->
    <!--  UPRAWNIENIA                                            -->
    <!-- ════════════════════════════════════════════════════════ -->

    <!-- Zapis QuickDump na /sdcard/ -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28"/>
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32"/>

    <!-- Android 13+ — granular media permissions -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES"/>
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"/>

    <!-- logcat — wymaga root lub signature perm -->
    <uses-permission android:name="android.permission.READ_LOGS"/>

    <!-- Restart do Recovery/Download (su wywołuje /sbin/reboot) -->
    <uses-permission android:name="android.permission.REBOOT"/>

    <!-- Stan baterii dla Battery Guard -->
    <uses-permission android:name="android.permission.BATTERY_STATS"/>

    <!-- Foreground Service dla długotrwałego shell I/O (opcjonalne) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC"/>

    <!-- ════════════════════════════════════════════════════════ -->
    <!--  APPLICATION                                            -->
    <!-- ════════════════════════════════════════════════════════ -->
    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="PirateDroid"
        android:theme="@style/Theme.PirateDroid"
        android:requestLegacyExternalStorage="true"
        android:hardwareAccelerated="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:windowSoftInputMode="adjustResize|stateHidden"
            android:screenOrientation="portrait">

            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>

        </activity>

    </application>

</manifest>